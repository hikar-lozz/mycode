[ T i t l e ]
minimized input file for lecture

[ P a r a m e t e r s ]
 icntl    =         0     # (D=0) 3:ECH 5:NOR 6:SRC 7:Geo.check,8:GSH 11:DSH 12:DUMP
 maxcas   =       4e7     # (D=10) number of particles per one batch
 maxbch   =        10     # (D=10) number of batches
 ipnint   =         0      # photo nuclear reaction
 file(6)  = phits.out       # (D=phits.out) general output file name
# dmax(2)  = 20.0000000     # (D=emin(2)) data max. energy of neutron (MeV)
# emin(2)  = 1e-10 # (D=1.0) cut-off energy of neutron (MeV)
 e-mode = 1
 esmin = 1.e-8
 file(7)  = c:/phits/data/xsdir.jnd # (D=xdirs) nuclear data input file name
 file(14) = c:/phits/data/trxcrd.dat # (D=trxcrd.dat) photon data input file name
 nspred = 2 $ （推奨）クーロン散乱を考慮する。Moliere 理論に基づくLynch の式[30] (Manual p.47)
 nedisp = 1 $ （推奨）エネルギー分散を考慮する。Landau Vavilov[31] (Manual p.47)
 negs = 1
 nlost = 1000
 
[ S o u r c e ]
 <source> = 1
   s-type = 9               # mono-energetic axial source
     proj = proton          # kind of incident particle     
       x0 = 0
       y0 = 0
       z0 = 0
       r1 = 0
       r2 = 0.005    
      dir = all           
   e-type = 5
     f(x) = 0.2
       nm = 50
      eg1 = 1
      eg2 = 5

 <source> = 1
   s-type = 9               # mono-energetic axial source
     proj = proton          # kind of incident particle     
       x0 = 0
       y0 = 0
       z0 = 0
       r1 = 0
       r2 = 0.005    
      dir = all           
   e-type = 5
     f(x) = exp(2.78 - 0.877 * x)
       nm = 50
      eg1 = 5
      eg2 = 9

 <source> = 1
   s-type = 9               # mono-energetic axial source
     proj = proton          # kind of incident particle     
       x0 = 0
       y0 = 0
       z0 = 0
       r1 = 0
       r2 = 0.005    
      dir = all           
   e-type = 5
     f(x) = exp(-2.64 - 0.275 * x)
       nm = 50
      eg1 = 9
      eg2 = 13

 <source> = 1
   s-type = 9               # mono-energetic axial source
     proj = 6000012         # kind of incident particle     
       x0 = 0
       y0 = 0
       z0 = 0
       r1 = 0
       r2 = 0.005    
      dir = all             
   e-type = 5
     f(x) = exp(-2.33 - 0.110 * x)
       nm = 480
      eg1 = 3
      eg2 = 50       

[ M a t e r i a l ]
 mat[1]     Fe 1 
 mat[2]     Ta 1
 mat[3]    12C 1  1H 1
 mat[4]     1H 2 16O 1
 mat[5]    12C 1 H 1   $ HD-V2 active layer
 mat[6]    12C 10 1H 10 16O 5  $ HD-V2 mylar 
 mat[7]    Al 1
 
[ T r a n s f o r m ]
 set: c1[3.0]
 set: c2[0.0050]
 set: c3[0.0012]
 set: c4[0.0097]
 *TR1  0 0 0  45 0 0  0 0 0  0 0 0  2 

