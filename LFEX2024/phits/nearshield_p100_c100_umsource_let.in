[ T - L E T ]
     mesh =  xyz              # mesh type is xyz scoring mesh
   x-type =    2              # x-mesh is linear given by xmin, xmax and nx
       nx =   84              # number of x-mesh points
     xmin = -0.42              # minimum value of x-mesh points
     xmax =  0.42              # maximum value of x-mesh points
   y-type =    2              
       ny =   84              
     ymin = -0.42
     ymax =  0.42
   z-type =    1              
       nz =    3
     3.0159 3.0171 3.0486 3.0498      
   l-type =    2              
       nl =   20
     lmin =    0              # keV/um
     lmax =  200
     part =  proton
     axis =  let
     file = t_let_proton.dat
     unit =    6              # MeV/source

